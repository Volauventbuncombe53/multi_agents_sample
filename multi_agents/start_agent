#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'USAGE'
Usage:
  ./multi_agents/start_agent finder [bug_focus_prompt]
  ./multi_agents/start_agent {identifier|reflector}
  ./multi_agents/start_agent fixer <branch_name>

Starts the requested Codex agent from the repository root.
For `finder`, an optional natural-language prompt can narrow what bugs to look for.
For `fixer`, checks out the provided branch before starting Codex.
If the branch does not exist, it is created and checked out.
USAGE
}

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(cd "$script_dir/.." && pwd)"
signal_file="$repo_root/multi_agents/signal"

rm -f "$signal_file"

pane_has_child_process() {
  local target_pane="$1"
  local pane_pid=""

  pane_pid="$(tmux display-message -p -t "$target_pane" '#{pane_pid}')"
  if [[ -z "$pane_pid" ]]; then
    return 1
  fi

  if command -v pgrep >/dev/null 2>&1; then
    pgrep -P "$pane_pid" >/dev/null 2>&1
    return
  fi

  ps -o pid= --ppid "$pane_pid" 2>/dev/null | grep -q '[0-9]'
}

write_current_env_file() {
  local env_file="$1"
  local name=""
  local value=""

  : > "$env_file"
  while IFS='=' read -r name value; do
    [[ -n "$name" ]] || continue
    [[ "$name" =~ ^[A-Za-z_][A-Za-z0-9_]*$ ]] || continue
    case "$name" in
      PWD|OLDPWD|SHLVL|_|TMUX|TMUX_PANE|TERM|TERMINFO|TERMCAP|LINES|COLUMNS)
        continue
        ;;
    esac
    printf 'export %s=%q\n' "$name" "$value" >> "$env_file"
  done < <(env)
}

start_codex_in_pane() {
  local target_pane="$1"
  local env_file=""
  local startup_cmd=""

  env_file="$(mktemp "${TMPDIR:-/tmp}/codexrun.env.XXXXXX")"
  write_current_env_file "$env_file"
  printf -v startup_cmd '. %q && rm -f %q && cd %q && codex --sandbox danger-full-access' "$env_file" "$env_file" "$repo_root"
  sleep 3
  tmux send-keys -t "$target_pane" C-c
  tmux send-keys -t "$target_pane" -l "$startup_cmd"
  tmux send-keys -t "$target_pane" Enter
}

wait_for_signal_or_idle() {
  local target_pane="$1"
  local expected_signal_file="$2"
  local idle_timeout_before_signal_seconds=600
  local idle_timeout_after_signal_seconds=30
  local poll_interval_seconds=2
  local last_snapshot=""
  local current_snapshot=""
  local last_change_epoch="$(date +%s)"
  local now_epoch=""
  local signal_seen=0
  local idle_timeout_seconds=$idle_timeout_before_signal_seconds

  while true; do
    current_snapshot="$(tmux capture-pane -p -t "$target_pane" -S -200 2>/dev/null || true)"
    now_epoch="$(date +%s)"

    if [[ "$current_snapshot" != "$last_snapshot" ]]; then
      last_snapshot="$current_snapshot"
      last_change_epoch="$now_epoch"
    fi

    if [[ $signal_seen -eq 0 && -e "$expected_signal_file" ]]; then
      signal_seen=1
      idle_timeout_seconds=$idle_timeout_after_signal_seconds
      last_change_epoch="$now_epoch"
    fi

    if (( now_epoch - last_change_epoch >= idle_timeout_seconds )); then
      return 0
    fi

    sleep "$poll_interval_seconds"
  done
}

codexrun() {
  local prompt="$1"
  local session_name="codexrun"
  local target_pane=""
  local started_codex=0
  local shell_ready=0

  if ! command -v tmux >/dev/null 2>&1; then
    echo "tmux is required for codexrun but was not found in PATH." >&2
    exit 1
  fi

  if ! tmux has-session -t "$session_name" 2>/dev/null; then
    target_pane="$(tmux new-session -d -P -F '#{pane_id}' -s "$session_name" -c "$repo_root")"
    shell_ready=1
  else
    target_pane="$(tmux list-panes -t "$session_name" -F '#{pane_id}' | head -n 1)"
  fi

  if [[ -z "$target_pane" ]]; then
    echo "Failed to resolve tmux pane for session '$session_name'." >&2
    exit 1
  fi

  if [[ "$(tmux display-message -p -t "$target_pane" '#{pane_dead}')" == "1" ]]; then
    tmux respawn-pane -k -t "$target_pane" -c "$repo_root"
    shell_ready=1
  fi

  if [[ "$shell_ready" -eq 1 ]]; then
    sleep 0.2
  fi

  if ! pane_has_child_process "$target_pane"; then
    start_codex_in_pane "$target_pane"
    started_codex=1
  fi

  if [[ "$started_codex" -eq 1 ]]; then
    sleep 1
  fi

  tmux send-keys -t "$target_pane" -l "/new"
  sleep 5
  tmux send-keys -t "$target_pane" Enter
  sleep 1
  tmux send-keys -t "$target_pane" -l "$prompt"
  sleep 1
  tmux send-keys -t "$target_pane" Enter
  wait_for_signal_or_idle "$target_pane" "$signal_file"
}

if [[ $# -lt 1 ]]; then
  usage
  exit 1
fi

role="$1"
branch_name="${2:-}"
finder_focus_prompt="${*:2}"
signal_instruction="After all your tasks finish, including any git commit and every other operation, create the file ./multi_agents/signal as the very last step by running 'touch ./multi_agents/signal'. Do not create it before you are completely done."

mkdir -p "$repo_root/multi_agents/bugs"
cd "$repo_root"

case "$role" in
  finder)
    if [[ $# -lt 1 ]]; then
      usage
      exit 1
    fi
    prompt='You are Bug Finder. Please refer to ./multi_agents/bug_finder.md and follow it strictly to find bugs. Your working directory is the repository root ./, not ./multi_agents. Use ./multi_agents/bugs/ for agent communication. Use the repo skills named there, especially `playwright-interactive` and `playwright-visible-browser` for visible browser investigation.'
    if [[ -n "$finder_focus_prompt" ]]; then
      prompt+=" Focus your bug hunt on this user-provided area or goal: $finder_focus_prompt"
    fi
    ;;
  identifier)
    if [[ $# -ne 1 ]]; then
      usage
      exit 1
    fi
    prompt='You are Bug Identifier. Please refer to ./multi_agents/bug_identifier.md and follow it strictly to identify whether a finder report is a real bug. Your working directory is the repository root ./, not ./multi_agents. Use ./multi_agents/bugs/ for agent communication.'
    ;;
  reflector)
    if [[ $# -ne 1 ]]; then
      usage
      exit 1
    fi
    prompt='You are Reflector. Please refer to ./multi_agents/reflector.md and follow it strictly to review bug-finding, identification, and repair outcomes. Your working directory is the repository root ./, not ./multi_agents. Use ./multi_agents/bugs/ for agent communication.'
    ;;
  fixer)
    if [[ $# -ne 2 ]]; then
      usage
      exit 1
    fi

    if git show-ref --verify --quiet "refs/heads/$branch_name"; then
      git checkout "$branch_name"
    elif git show-ref --verify --quiet "refs/remotes/origin/$branch_name"; then
      git checkout -b "$branch_name" --track "origin/$branch_name"
    else
      git checkout -b "$branch_name"
    fi

    prompt="You are Bug Fixer. Please refer to ./multi_agents/bug_fixer.md and follow it strictly to repair the most recent eligible bug case. Your working directory is the repository root ./, not ./multi_agents. Use ./multi_agents/bugs/ for agent communication. The user provided branch '$branch_name' before Codex started, so you may create git commits on this checked-out branch after your focused verification test passes."
    ;;
  -h|--help|help)
    usage
    exit 0
    ;;
  *)
    echo "Unknown agent role: $role" >&2
    usage >&2
    exit 1
    ;;
esac

prompt+=" $signal_instruction"

codexrun "$prompt"
